{
  "name": "web-translator",
  "description": "AI 网页翻译 Chrome 插件：文本 / PDF / 图片 / 漫画",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,html,json,css,md}\"",
    "sync:ort": "node scripts/copy-ort.mjs",
    "fetch:models": "node scripts/fetch-paddle-models.mjs",
    "postinstall": "wxt prepare && node scripts/copy-ort.mjs && node scripts/fetch-paddle-models.mjs"
  },
  "dependencies": {
    "onnxruntime-web": "^1.26.0",
    "pdfjs-dist": "^6.0.227",
    "ppu-paddle-ocr": "^5.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "onnxruntime-node": "^1.26.0",
    "prettier": "^3.4.0",
    "puppeteer-core": "^25.1.0",
    "sharp": "^0.35.2",
    "typescript": "^6.0.0",
    "wxt": "^0.20.26"
  }
}
